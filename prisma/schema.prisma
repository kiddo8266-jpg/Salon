// WellnessOS - Multi-Tenant Prisma Schema
// Production-ready with full tenant isolation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum BusinessCategory {
  SALON
  CLINIC
  GYM
  SAUNA
  SPA
  WELLNESS_CENTER
}

enum UserRole {
  OWNER
  STAFF
  VIEWER
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum PaymentMethod {
  CASH
  CARD
  ONLINE
  BANK_TRANSFER
}

enum PlanType {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

// ─────────────────────────────────────────────
// CORE MODELS
// ─────────────────────────────────────────────

model Tenant {
  id            String           @id @default(cuid())
  name          String
  slug          String           @unique
  category      BusinessCategory @default(SALON)
  logoUrl       String?
  coverImageUrl String?
  themeColor    String           @default("#7C3AED")
  tagline       String?
  website       String?
  phone         String?
  email         String?
  address       String?
  city          String?
  country       String?
  zipCode       String?
  planType      PlanType         @default(FREE)
  isActive      Boolean          @default(true)
  workingHours  Json?            // { mon: { open: "09:00", close: "18:00", isOpen: true }, ... }
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  // Relations
  users        User[]
  clients      Client[]
  services     Service[]
  staff        Staff[]
  appointments Appointment[]
  payments     Payment[]
  media        Media[]

  @@index([slug])
  @@map("tenants")
}

model User {
  id             String   @id @default(cuid())
  tenantId       String
  email          String
  name           String?
  password       String?  // hashed, null for OAuth users
  avatarUrl      String?
  role           UserRole @default(STAFF)
  emailVerified  DateTime?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staff          Staff?
  accounts       Account[]
  sessions       Session[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Client {
  id          String   @id @default(cuid())
  tenantId    String
  fullName    String
  email       String?
  phone       String?
  avatarUrl   String?
  dateOfBirth DateTime?
  gender      String?
  address     String?
  notes       String?  @db.Text
  tags        String[] // e.g. ["VIP", "Regular", "New"]
  totalVisits Int      @default(0)
  totalSpent  Float    @default(0)
  loyaltyTier String   @default("Bronze") // Bronze, Silver, Gold, Platinum
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, fullName])
  @@map("clients")
}

model Service {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  description  String?  @db.Text
  category     String   // Hair, Massage, Skincare, Nails, etc.
  duration     Int      // minutes
  price        Float
  color        String   @default("#7C3AED") // for calendar color coding
  isActive     Boolean  @default(true)
  imageUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  staffServices StaffService[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("services")
}

model Staff {
  id             String   @id @default(cuid())
  tenantId       String
  userId         String   @unique
  specialization String?
  bio            String?  @db.Text
  rating         Float    @default(0)
  workingHours   Json?    // Same pattern as Tenant.workingHours
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  staffServices StaffService[]

  @@index([tenantId])
  @@map("staff")
}

// Junction table: which staff can perform which services
model StaffService {
  staffId   String
  serviceId String

  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([staffId, serviceId])
  @@map("staff_services")
}

model Appointment {
  id         String            @id @default(cuid())
  tenantId   String
  clientId   String
  staffId    String
  serviceId  String
  startTime  DateTime
  endTime    DateTime
  status     AppointmentStatus @default(PENDING)
  notes      String?           @db.Text
  cancelNote String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  // Relations
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  staff    Staff    @relation(fields: [staffId], references: [id])
  service  Service  @relation(fields: [serviceId], references: [id])
  payment  Payment?

  @@index([tenantId])
  @@index([tenantId, startTime])
  @@index([tenantId, staffId, startTime]) // for double-booking check
  @@index([tenantId, clientId])
  @@index([status])
  @@map("appointments")
}

model Payment {
  id            String        @id @default(cuid())
  tenantId      String
  appointmentId String        @unique
  amount        Float
  method        PaymentMethod @default(CASH)
  status        PaymentStatus @default(PENDING)
  note          String?
  paidAt        DateTime?
  refundedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("payments")
}

model Media {
  id          String   @id @default(cuid())
  tenantId    String
  url         String
  key         String   // UploadThing key or local path key
  filename    String?
  mimeType    String?
  fileSize    Int?     // bytes
  altText     String?
  isCover     Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("media")
}
